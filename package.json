{
  "name": "aridhsmart",
  "version": "1.0.0",
  "description": "CodeIgniter is a PHP full-stack web framework that is light, fast, flexible and secure. More information can be found at the [official site](https://codeigniter.com).",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "php spark serve --port 8081",
    "copy-to-pub": "copy-files-from-to --when-file-exists overwrite"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiwenda100/Ardhi-Smart.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/chiwenda100/Ardhi-Smart/issues"
  },
  "homepage": "https://github.com/chiwenda100/Ardhi-Smart#readme",
  "dependencies": {
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "bootstrap-vue": "^2.23.1",
    "copy-files-from-to": "^4.0.0",
    "sass": "^1.97.3",
    "vue": "^2.7.16"
  },
   "copyFilesSettings": [
    {
      "whenFileExists": "overwrite",
      "ignoreDotFilesAndFolders": false
    }
  ],
  "copyFiles": [
    {
      "from": "node_modules/axios/dist/**/*",
      "to": "public/node_modules/axios/"
    },
    {
      "from": "node_modules/bootstrap/dist/**/*",
      "to": "public/node_modules/bootstrap/"
    },
    {
      "from": "node_modules/bootstrap-vue/dist/**/*",
      "to": "public/node_modules/bootstrap-vue/"
    },
    {
      "from": "node_modules/vue/dist/**/*",
      "to": "public/node_modules/vue/"
    },
    {
      "from": "node_modules/sass/**/*",
      "to": "public/node_modules/sass/"
    }
  ]
}
